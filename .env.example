# Intercom REST API token (Developer Hub → Authentication)
# https://app.intercom.com/a/apps/_/developer-hub
INTERCOM_ACCESS_TOKEN=

# Google Gemini API key (for conversation issue summaries + topic classification)
# https://aistudio.google.com/apikey
# Bulk exports use the Batch API (--batch) for 50% lower cost: https://ai.google.dev/gemini-api/docs/batch-api
GEMINI_API_KEY=

# Anthropic Claude API key (for the /docs-ai KYC document pre-check POC)
# https://platform.claude.com/
CLAUDE_API_KEY=
# Optional: override the pre-check model (default: claude-haiku-4-5)
# CLAUDE_PRECHECK_MODEL=claude-sonnet-4-6

# Password for encrypting public/support-data.enc.json (Support Insights dashboard).
# Run: SUPPORT_DATA_PASSWORD=... npm run intercom:dashboard-data
# Local dev without password: npm run intercom:dashboard-data:local
SUPPORT_DATA_PASSWORD=
